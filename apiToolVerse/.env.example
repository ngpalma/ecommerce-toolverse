# Base de datos PostgreSQL
DB_USER=postgres
DB_PASSWORD=tu_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=toolverse

# Servidor
PORT=3001
NODE_ENV=development

# URL del frontend (para CORS y links en emails)
CLIENT_URL=http://localhost:3000

# JWT
TOKEN_SECRET=cambia_esto_por_una_clave_secreta_larga_y_aleatoria

# Mercado Pago
PROD_ACCESS_TOKEN=tu_access_token_de_mercadopago

# Email (Gmail con contraseña de aplicación)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_password_de_aplicacion_gmail
EMAIL_FROM=Toolverse <tu_email@gmail.com>
CONTACT_EMAIL=email_destino_de_contacto@gmail.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Administrador inicial (usado por: npm run create-admin)
ADMIN_EMAIL=admin@toolverse.com
ADMIN_PASSWORD=Admin1234!
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Toolverse
ADMIN_PHONE=1100000000
